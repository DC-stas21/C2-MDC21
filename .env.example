APP_NAME="C2 MDC21"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://c2-mdc21.test

APP_LOCALE=es
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=es_ES

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=c2
DB_USERNAME=postgres
DB_PASSWORD=

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
# CACHE_PREFIX=

REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# --- Reverb (WebSockets) ---
REVERB_APP_ID=c2-mdc21
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=127.0.0.1
REVERB_PORT=8080
REVERB_SCHEME=http

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# --- Horizon ---
HORIZON_DOMAIN=
HORIZON_PATH=horizon

# --- AI APIs ---
CLAUDE_API_KEY=
CLAUDE_MODEL_ORCHESTRATOR=claude-sonnet-4-5
CLAUDE_MODEL_POLICY=claude-haiku-4-5
OPENAI_API_KEY=
OPENAI_MODEL_RESEARCH=gpt-4o
OPENAI_MODEL_CONTENT=gpt-4o-mini

# --- Telegram ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_GROUP_INFRA=
TELEGRAM_GROUP_CONTENT=
TELEGRAM_GROUP_NEGOCIO=

# --- Resend (email) ---
RESEND_API_KEY=
MAIL_MAILER=resend
MAIL_FROM_ADDRESS="noreply@mdc21.agency"
MAIL_FROM_NAME="${APP_NAME}"

# --- AWS ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-west-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# --- Cloudflare ---
CLOUDFLARE_API_TOKEN=

# --- GitHub ---
GITHUB_TOKEN=

# --- Google Search Console ---
GOOGLE_SEARCH_CONSOLE_KEY=

# --- SEMrush ---
SEMRUSH_API_KEY=

# --- Sentry ---
SENTRY_LARAVEL_DSN=

VITE_APP_NAME="${APP_NAME}"
